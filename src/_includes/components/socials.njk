<section id="socials">
  <div class="container">
    <h2 class="will-animate title">Nossas redes</h2>
    <br>
        <div class="socialIcons">
          {% for social in meta.socials %}
            <a class="socialIcon" href="{{ social.url }}" {{ social.target }}>
              <div class="will-animate">
                <img class="will-animate mx-auto" height="100px" width="100px" src="{{ meta.url }}/{{ social.icon }}" alt="{{ social.name }}" ></img>
                <p class="will-animate">{{ social.name }}</p>
              </div>
            </a>
          {% endfor %}
        </div>
  </div>
</section>