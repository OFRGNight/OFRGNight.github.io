<section id="team">
  <div class="container">
    <h2 class="will-animate title">Conheça nossa equipe</h2>
    <br>
    <div class="teamMembers">
      {% for member in meta.team %}
        <div class="will-animate memberCard">
          <img class="will-animate avatar mx-auto" src="{{ meta.url }}/{{ member.image }}" alt="{{ member.name }}" />
          <h3 class="will-animate name">{{ member.name }}</h3>
          <p class="will-animate role">{{ member.role }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>